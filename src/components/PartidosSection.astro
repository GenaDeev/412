    >
      <div class="lg:col-span-5 flex flex-col gap-6 w-full animate-left">
        <div
          class="match-card relative overflow-hidden flex flex-col items-center p-8 rounded-2xl border border-red-500/20 bg-[#0f0a0a]/75 backdrop-blur-md shadow-2xl"
        >
          <div class="fire-glow"></div>

          <div class="flex flex-col items-center text-center gap-1 mb-8 z-10">
            <span
              class="match-date text-[0.75rem] font-bold text-white/50 tracking-[2px] uppercase"
            >
              31 DE MAYO DE 2026
            </span>
            <span
              class="match-relator text-[0.7rem] font-medium text-red-500/80 tracking-[1px] uppercase"
            >
              Relatos de Sebastián "Pollo" Vignolo
            </span>
          </div>

          <div class="flex items-center justify-between w-full gap-4 z-10 mb-8">
            <div class="flex flex-col items-center text-center flex-1">
              <Image
                src={escudo412}
                alt="Escudo de 412"
                class="shield-img shield-412 w-20 h-20 md:w-24 md:h-24 object-contain transition-transform hover:scale-105 duration-300"
                width={96}
                height={96}
              />
              <span
                class="team-name text-sm md:text-base font-black tracking-wider text-white mt-3 uppercase"
              >
                412
              </span>
            </div>

            <div class="flex flex-col items-center justify-center gap-1 px-4">
              <div class="flex items-center gap-3">
                <span
                  class="score text-5xl md:text-7xl font-black tracking-tight text-white font-mono"
                >
                  6
                </span>
                <span
                  class="score-divider text-2xl md:text-3xl font-black text-white/30 font-mono"
                >
                  -
                </span>
                <span
                  class="score text-5xl md:text-7xl font-black tracking-tight text-white font-mono"
                >
                  6
                </span>
              </div>
              <div
                class="penalty-badge px-3 py-1 rounded-full bg-red-500/10 border border-red-500/30 text-[0.65rem] font-black tracking-[1.5px] text-red-500 uppercase mt-2"
