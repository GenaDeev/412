    <div class="text-center animate-up">
      <h2
        class="section-title text-4xl md:text-6xl font-black italic tracking-tighter uppercase text-white m-0"
      >
        PARTIDOS
      </h2>
      <span
        class="section-subtitle text-xs md:text-sm text-white/40 tracking-[3px] uppercase mt-2 block"
      >
        Jugadores, la concha de su madre.
      </span>
    </div>

