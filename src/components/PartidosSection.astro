<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import 'lite-youtube-embed';
  import 'lite-youtube-embed/src/lite-yt-embed.css';

  gsap.registerPlugin(ScrollTrigger);

  const tabBtns = document.querySelectorAll('.tab-btn');
  const tabContents = document.querySelectorAll('.tab-content');

  tabBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tabName = btn.getAttribute('data-tab');
      tabBtns.forEach((b) => {
        b.classList.toggle('active', b === btn);
        if (b === btn) {
          b.classList.add('border-white/10');
          b.classList.remove('border-transparent');
        } else {
          b.classList.remove('border-white/10');
          b.classList.add('border-transparent');
        }
      });

      tabContents.forEach((content) => {
        const contentId = content.getAttribute('id');
        content.classList.toggle('active', contentId === `tab-${tabName}`);
      });
    });
  });

  const partidosTl = gsap.timeline({
    scrollTrigger: {
      trigger: '.partidos-section',
      start: 'top 75%',
    },
  });

  partidosTl
    .fromTo(
      '.partidos-section .section-title',
      { opacity: 0, y: 30 },
      { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' },
    )
    .fromTo(
      '.partidos-section .section-subtitle',
      { opacity: 0, y: 15 },
      { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' },
      '-=0.5',
    )
    .fromTo(
      '.partidos-section .animate-left',
      { opacity: 0, x: -50 },
      { opacity: 1, x: 0, duration: 1, ease: 'power3.out' },
      '-=0.3',
    )
    .fromTo(
      '.partidos-section .animate-right',
      { opacity: 0, x: 50 },
      { opacity: 1, x: 0, duration: 1, ease: 'power3.out' },
      '-=1',
    )
    .fromTo(
      '.partidos-section .graffiti',
      { opacity: 0, scale: 0.8 },
      {
        opacity: (index: number) => {
          const opacities = [0.4, 0.35, 0.3, 0.25];
          return opacities[index];
        },
        scale: 1,
        duration: 1.2,
        stagger: 0.15,
        ease: 'back.out(1.2)',
      },
      '-=0.8',
    );
</script>

