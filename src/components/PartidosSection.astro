        <div class="video-container flex flex-col gap-3 w-full">
          <span
            class="text-[0.65rem] font-bold text-white/40 tracking-[3px] uppercase mt-2 select-none"
          >
            Resumen del Partido
          </span>
          <div
            class="video-wrapper relative w-full overflow-hidden rounded-2xl border border-white/10 shadow-2xl bg-[#0f0a0a]"
          >
            <lite-youtube
              videoid="YanyIcXhlbk"
              playlabel="Ver Resumen del Partido"
              style="background-image: url('https://i.ytimg.com/vi_webp/YanyIcXhlbk/sddefault.webp'); background-size: cover; background-position: center;"
              class="w-full aspect-video"></lite-youtube>
          </div>
        </div>
