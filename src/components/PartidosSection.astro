                Luzu Gana 3-2 en Penales
              </div>
            </div>

            <div class="flex flex-col items-center text-center flex-1">
              <Image
                src={escudoluzu}
                alt="Escudo de Luzu"
                class="shield-img shield-luzu w-20 h-20 md:w-24 md:h-24 object-contain transition-transform hover:scale-105 duration-300"
                width={96}
                height={96}
              />
              <span
                class="team-name text-sm md:text-base font-black tracking-wider text-white mt-3 uppercase"
