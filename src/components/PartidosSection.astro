                Luzu
              </span>
            </div>
          </div>

          <div
            class="revancha-banner w-full py-3 px-6 rounded-xl border border-orange-500/30 bg-gradient-to-r from-orange-600/10 to-red-600/10 flex items-center justify-center z-10"
          >
            <span
              class="revancha-text text-base md:text-lg font-black tracking-[4px] text-orange-500 uppercase animate-pulse"
            >
              Habrá Revancha
            </span>
          </div>
