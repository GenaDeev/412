---
import { Image } from 'astro:assets';
import logo from '../assets/images/logo.webp';
---

<header id="main-header" class="fixed top-0 left-0 w-full z-50">
  <div
    class="header-container max-w-7xl mx-auto px-6 py-4 flex justify-between items-center"
  >
    <a href="#hero" class="logo-link flex items-center">
      <Image src={logo} alt="412 Logo" class="w-12 h-auto" />
    </a>

    <nav class="hidden md:flex items-center gap-8">
      <a href="#hero" class="nav-link">Los muchachos</a>
      <a href="#info" class="nav-link">El programa</a>
    </nav>

    <div class="flex items-center gap-4">
      <a
        href="https://kick.com/davoxeneize"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-white/5 border border-white/10 text-white/80 transition-all duration-300 ease-in-out kick-hover"
        aria-label="Ver en Kick"
      >
        <svg class="w-5 h-5" viewBox="0 0 512 512" fill="currentColor">
          <path
            d="M37 .036h164.448v113.621h54.71v-56.82h54.731V.036h164.448v170.777h-54.73v56.82h-54.711v56.8h54.71v56.82h54.73V512.03H310.89v-56.82h-54.73v-56.8h-54.711v113.62H37V.036z"
          ></path>
        </svg>
      </a>
      <a
        href="https://www.youtube.com/@programa412"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-white/5 border border-white/10 text-white/80 transition-all duration-300 ease-in-out yt-hover"
        aria-label="Ver en YouTube"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M23.498 6.163a3.003 3.003 0 0 0-2.11-2.11C19.517 3.545 12 3.545 12 3.545s-7.517 0-9.388.508a3.003 3.003 0 0 0-2.11 2.11C0 8.033 0 12 0 12s0 3.967.502 5.837a3.003 3.003 0 0 0 2.11 2.11c1.871.508 9.388.508 9.388.508s7.517 0 9.388-.508a3.003 3.003 0 0 0 2.11-2.11C24 15.967 24 12 24 12s0-3.967-.502-5.837zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
          ></path>
        </svg>
      </a>
    </div>
  </div>
</header>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  ScrollTrigger.create({
    trigger: '.hero-section',
    start: 'bottom top',
    onEnter: () => {
      gsap.to('#main-header', {
        y: 0,
        opacity: 1,
        duration: 0.4,
        ease: 'power2.out',
      });
    },
    onLeaveBack: () => {
      gsap.to('#main-header', {
        y: '-100%',
        opacity: 0,
        duration: 0.3,
        ease: 'power2.in',
      });
    },
  });
</script>

<style>
  #main-header {
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(74, 222, 128, 0.08);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.8);
    transform: translateY(-100%);
    opacity: 0;
  }

  .logo-link img {
    filter: drop-shadow(0 0 4px rgba(0, 231, 1, 0.3));
    transition:
      filter 0.3s ease,
      transform 0.3s ease;
  }

  .logo-link:hover img {
    filter: drop-shadow(0 0 10px #00e701);
    transform: scale(1.05);
  }

  .nav-link {
    position: relative;
    font-family: 'Inter', sans-serif;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .nav-link:hover {
    color: #00e701;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: #00e701;
    box-shadow: 0 0 8px #00e701;
    transition: width 0.3s ease;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .kick-hover:hover {
    background: #00e701;
    border-color: #00e701;
    color: #000;
    box-shadow: 0 0 15px rgba(0, 231, 1, 0.5);
    transform: translateY(-2px);
  }

  .yt-hover:hover {
    background: #ff0000;
    border-color: #ff0000;
    color: #fff;
    box-shadow: 0 0 15px rgba(255, 0, 0, 0.5);
    transform: translateY(-2px);
  }
</style>
