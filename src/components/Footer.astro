    <nav class="flex gap-8 text-sm font-semibold tracking-wider">
      <a href="#hero" class="nav-link">Los muchachos</a>
      <a href="#partidos" class="nav-link">Partidos</a>
      <a href="#info" class="nav-link">El programa</a>
      <a href="#historia" class="nav-link">Historia</a>
