  >
    <div class="flex flex-col items-center md:items-start gap-4">
      <div class="logo-wrapper">
        <Image src={logo} alt="412 Logo" class="footer-logo" width={150} height={84} />
      </div>
      <p class="text-xs text-white/60 text-center md:text-left leading-relaxed">
        &copy; {new Date().getFullYear()} 412 - El Programa de Fútbol. Todos los derechos
        reservados.<br />
        412, sus imágenes y producciones son propiedad de Doxen Management y David
        Quint.
      </p>
      <!-- Redes del Programa -->
      <div class="flex gap-3 justify-center md:justify-start">
        <a
          href="https://kick.com/davooxeneize"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-white/[0.03] border border-white/[0.05] text-white/50 transition-all duration-300 ease-in-out social-btn kick-hover-footer"
          aria-label="412 en Kick"
        >
