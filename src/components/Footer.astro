    <div class="flex flex-col items-center md:items-end gap-3">
      <p class="text-xs text-white/50">
        Desarrollado por <a
          href="https://github.com/GenaDeev"
          target="_blank"
          rel="noopener noreferrer"
          class="credit-link">GenaDeev</a
        >
      </p>
      <div class="flex gap-4">
        <a
          href="https://github.com/GenaDeev"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-white/[0.03] border border-white/[0.05] text-white/60 transition-all duration-300 ease-in-out social-btn"
          aria-label="GitHub de GenaDeev"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.138 20.161 22 16.418 22 12c0-5.523-4.477-10-10-10z"
            ></path>
          </svg>
        </a>
        <a
          href="https://linkedin.com/in/genadev"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-white/[0.03] border border-white/[0.05] text-white/60 transition-all duration-300 ease-in-out social-btn"
          aria-label="LinkedIn de GenaDeev"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path
              fill-rule="evenodd"
              d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
              clip-rule="evenodd"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 -10px 30px rgba(0, 0, 0, 0.5);
  }

  .footer-border {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
    overflow: hidden;
  }

  .footer-border::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 200%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(0, 231, 1, 0.2) 20%,
      #00e701 50%,
      rgba(0, 231, 1, 0.2) 80%,
      transparent 100%
    );
    filter: drop-shadow(0 0 4px #00e701) drop-shadow(0 0 12px #00e701);
    animation: neon-flow 3.5s linear infinite;
  }

  @keyframes neon-flow {
    0% {
      transform: translateX(0%);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .logo-wrapper {
    display: inline-flex;
    justify-content: center;
    align-items: center;
  }

  .footer-logo {
    width: 150px;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 0 4px rgba(0, 231, 1, 0.3));
    transition:
      filter 0.3s ease,
      transform 0.3s ease;
  }

  .logo-wrapper:hover .footer-logo {
    filter: drop-shadow(0 0 10px #00e701);
    transform: scale(1.05);
  }

  .nav-link {
    position: relative;
    font-family: 'Inter', sans-serif;
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.85rem;
    font-weight: 700;
    text-align: center;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .nav-link:hover {
    color: #00e701;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: #00e701;
    box-shadow: 0 0 8px #00e701;
    transition: width 0.3s ease;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .credit-link {
    color: #00e701;
    font-weight: 700;
    text-decoration: none;
    transition: text-shadow 0.3s ease;
  }

  .credit-link:hover {
    text-shadow: 0 0 8px #00e701;
  }

  .social-btn:hover {
    background: rgba(0, 231, 1, 0.1);
    border-color: #00e701;
    color: #00e701;
    box-shadow: 0 0 10px rgba(0, 231, 1, 0.3);
    transform: translateY(-2px);
  }

  .kick-hover-footer:hover {
    background: rgba(0, 231, 1, 0.1) !important;
    border-color: #00e701 !important;
    color: #00e701 !important;
    box-shadow: 0 0 10px rgba(0, 231, 1, 0.3) !important;
  }

  .yt-hover-footer:hover {
    background: rgba(255, 0, 0, 0.1) !important;
    border-color: #ff0000 !important;
    color: #ff0000 !important;
    box-shadow: 0 0 10px rgba(255, 0, 0, 0.3) !important;
  }

  .ig-hover-footer:hover {
    background: rgba(225, 48, 108, 0.1) !important;
    border-color: #e1306c !important;
    color: #e1306c !important;
    box-shadow: 0 0 10px rgba(225, 48, 108, 0.3) !important;
  }

  .x-hover-footer:hover {
    background: rgba(255, 255, 255, 0.05) !important;
    border-color: #ffffff !important;
    color: #ffffff !important;
    box-shadow: 0 0 10px rgba(255, 255, 255, 0.2) !important;
  }

  .tt-hover-footer:hover {
    background: rgba(37, 244, 238, 0.1) !important;
    border-color: #25f4ee !important;
    color: #25f4ee !important;
    box-shadow: 0 0 10px rgba(37, 244, 238, 0.3) !important;
  }

  .fb-hover-footer:hover {
    background: rgba(24, 119, 242, 0.1) !important;
    border-color: #1877f2 !important;
    color: #1877f2 !important;
    box-shadow: 0 0 10px rgba(24, 119, 242, 0.3) !important;
  }
</style>
