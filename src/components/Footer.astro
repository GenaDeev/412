          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-white/[0.03] border border-white/[0.05] text-white/50 transition-all duration-300 ease-in-out social-btn fb-hover-footer"
