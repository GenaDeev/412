---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="w-full min-h-[80vh] flex flex-col justify-center items-center relative z-10 px-6 py-24 bg-black">
    <div class="absolute inset-0 bg-radial-glow opacity-10 pointer-events-none"></div>
    <div class="max-w-md w-full glass-card p-8 md:p-10 rounded-2xl border border-white/5 text-center relative z-10 shadow-[0_15px_35px_rgba(0,0,0,0.8)]">
      <div class="logo-404 text-kick font-black text-7xl md:text-8xl italic tracking-tight mb-4 select-none">404</div>
      <h1 class="text-2xl md:text-3xl font-black text-white italic uppercase mb-6 tracking-wide">
        Te fuiste al descenso
      </h1>
      <p class="text-neutral-400 text-sm md:text-base font-light leading-relaxed mb-8">
        La página que estás buscando no existe o fue eliminada del VAR. Volvé a la primera división antes de que el árbitro cobre el final del partido.
      </p>
      <a href="/" class="home-btn inline-block uppercase text-xs md:text-sm font-extrabold tracking-widest text-black bg-kick px-8 py-4 rounded-xl shadow-[0_0_20px_rgba(0,231,1,0.3)] transition-all duration-300 hover:scale-105 hover:shadow-[0_0_35px_rgba(0,231,1,0.5)]">
        Volver a la Home
      </a>
    </div>
  </main>
</Layout>

<style>
  .text-kick {
    color: #00e701;
    filter: drop-shadow(0 0 10px rgba(0, 231, 1, 0.4));
  }

  .bg-kick {
    background-color: #00e701;
  }

  .glass-card {
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .bg-radial-glow {
    background: radial-gradient(circle at center, rgba(0, 231, 1, 0.3) 0%, transparent 70%);
  }

  .logo-404 {
    font-family: 'Impact', 'Arial Black', sans-serif;
    animation: glitch 1.5s infinite alternate;
  }

  .home-btn {
    font-family: 'Inter', sans-serif;
  }

  @keyframes glitch {
    0% {
      transform: skew(0deg);
    }
    20% {
      transform: skew(-1deg);
    }
    40% {
      transform: skew(1deg);
    }
    60% {
      transform: skew(-2deg);
      filter: drop-shadow(-2px 0 0 #ff0000) drop-shadow(2px 0 0 #00e701);
    }
    80% {
      transform: skew(0deg);
      filter: drop-shadow(0 0 10px rgba(0, 231, 1, 0.4));
    }
    100% {
      transform: skew(1deg);
    }
  }
</style>
