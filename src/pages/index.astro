---
import Layout from '../layouts/Layout.astro';
import Image from 'astro/components/Image.astro';

import agus from '../assets/images/agus0.webp';
import teo from '../assets/images/teo0.webp';
import davo from '../assets/images/davo0.webp';
import nine from '../assets/images/nine0.webp';
import beno from '../assets/images/beno0.webp';
import logo from '../assets/images/logo.webp';

const players = [
  {
    id: 'p1',
    yt: 'AGUSNETA',
    realName: 'Agustín',
    age: '24',
    weight: '75kg',
    nicknames: 'Gordo, Agus',
    pos: 'DFC',
  },
  {
    id: 'p2',
    yt: "TEO D'ELIA",
    realName: 'Teo',
    age: '22',
    weight: '70kg',
    nicknames: 'Teito, Figo',
    pos: 'MCO',
  },
  {
    id: 'p3',
    yt: 'DAVO XENEIZE',
    realName: 'David',
    age: '21',
    weight: '65kg',
    nicknames: 'Puerro, Davito',
    pos: 'EI',
  },
  {
    id: 'p4',
    yt: 'LA COBRA',
    realName: 'Lautaro',
    age: '26',
    weight: '110kg',
    nicknames: 'Nine, Big Nine, Enormous Nine',
    pos: 'DC',
  },
  {
    id: 'p5',
    yt: 'BENITO SDR',
    realName: 'Benito',
    age: '23',
    weight: '70kg',
    nicknames: 'Beno',
    pos: 'DT',
  },
];
---

<Layout>
  <section
    id="hero"
    class="hero-section w-full h-screen flex flex-col justify-center items-center relative"
  >
    <div class="logo-container">
      <div>
        <Image class="logo" src={logo} alt="Logo de 412" />
        <div class="logo-aura"></div>
      </div>
    </div>
    <div class="scroll-indicator">
      <span>SCROLLEA</span>
      <div class="arrow"></div>
    </div>
    <div class="characters-container">
      <!--  Agusneta | Teo | Davo (centro) | La Cobra | Benito — formación en V -->
      <Image
        src={agus}
        class="character p1"
        alt="Agusneta"
        data-player="p1"
        width="400"
        height="600"
      />
      <Image
        src={teo}
        class="character p2"
        alt="Teo"
        data-player="p2"
        width="400"
        height="600"
      />
      <Image
        src={davo}
        class="character p3"
        alt="Davo"
        data-player="p3"
        width="400"
        height="600"
      />
      <Image
        src={nine}
        class="character p4"
        alt="La Cobra"
        data-player="p4"
        width="400"
        height="600"
      />
      <Image
        src={beno}
        class="character p5"
        alt="Benito"
        data-player="p5"
        width="400"
        height="600"
      />

      {
        players.map((p) => (
          <div class={`player-card card-${p.id} desktop-card`}>
            <div class="card-inner flex flex-col h-full">
              <h3 class="name">{p.yt}</h3>
              <div class="card-divider" />
              <div class="info-list flex flex-col gap-3">
                <div class="info-row text-[0.95rem] flex justify-between items-center">
                  <>
                    <span class="label text-white/50 font-medium text-[0.8rem] uppercase tracking-[1px]">
                      Nombre
                    </span>
                    <span class="val font-bold text-white text-right max-w-[60%]">
                      {p.realName}
                    </span>
                  </>
                </div>
                <div class="info-row text-[0.95rem] flex justify-between items-center">
                  <>
                    <span class="label text-white/50 font-medium text-[0.8rem] uppercase tracking-[1px]">
                      Edad
                    </span>
                    <span class="val font-bold text-white text-right max-w-[60%]">
                      {p.age}
                    </span>
                  </>
                </div>
                <div class="info-row text-[0.95rem] flex justify-between items-center">
                  <>
                    <span class="label text-white/50 font-medium text-[0.8rem] uppercase tracking-[1px]">
                      Peso
                    </span>
                    <span class="val font-bold text-white text-right max-w-[60%]">
                      {p.weight}
                    </span>
                  </>
                </div>
                <div class="info-row text-[0.95rem] flex justify-between items-center">
                  <>
                    <span class="label text-white/50 font-medium text-[0.8rem] uppercase tracking-[1px]">
                      Apodos
                    </span>
                    <span class="val font-bold text-white text-right max-w-[60%]">
                      {p.nicknames}
                    </span>
                  </>
                </div>
                <div class="info-row text-[0.95rem] flex justify-between items-center">
                  <>
                    <span class="label text-white/50 font-medium text-[0.8rem] uppercase tracking-[1px]">
                      Posición
                    </span>
                    <span class="val font-bold text-white text-right max-w-[60%]">
                      {p.pos}
                    </span>
                  </>
                </div>
              </div>
            </div>
          </div>
        ))
      }
      <div class="mobile-card-zone" id="mobile-card-zone">
        <div
          id="mobile-click-indicator"
          class="text-white/40 text-center w-full py-14 uppercase tracking-[0.2em] text-xs transition-opacity duration-300 absolute top-30 left-0 font-light"
        >
          Toca a alguuno de los pibes para ver sus datos
        </div>
        {
          players.map((p) => (
            <div class={`player-card-mobile card-mobile-${p.id}`}>
              <div class="card-inner flex flex-col">
                <h3 class="name">{p.yt}</h3>
                <div class="card-divider" />
                <div class="info-list flex flex-col gap-3">
                  <div class="info-row text-[0.95rem] flex justify-between items-center">
                    <>
                      <span class="label text-white/50 font-medium text-[0.8rem] uppercase tracking-[1px]">
                        Nombre
                      </span>
                      <span class="val font-bold text-white text-right max-w-[60%]">
                        {p.realName}
                      </span>
                    </>
                  </div>
                  <div class="info-row text-[0.95rem] flex justify-between items-center">
                    <>
                      <span class="label text-white/50 font-medium text-[0.8rem] uppercase tracking-[1px]">
                        Edad
                      </span>
                      <span class="val font-bold text-white text-right max-w-[60%]">
                        {p.age}
                      </span>
                    </>
                  </div>
                  <div class="info-row text-[0.95rem] flex justify-between items-center">
                    <>
                      <span class="label text-white/50 font-medium text-[0.8rem] uppercase tracking-[1px]">
                        Peso
                      </span>
                      <span class="val font-bold text-white text-right max-w-[60%]">
                        {p.weight}
                      </span>
                    </>
                  </div>
                  <div class="info-row text-[0.95rem] flex justify-between items-center">
                    <>
                      <span class="label text-white/50 font-medium text-[0.8rem] uppercase tracking-[1px]">
                        Apodos
                      </span>
                      <span class="val font-bold text-white text-right max-w-[60%]">
                        {p.nicknames}
                      </span>
                    </>
                  </div>
                  <div class="info-row text-[0.95rem] flex justify-between items-center">
                    <>
                      <span class="label text-white/50 font-medium text-[0.8rem] uppercase tracking-[1px]">
                        Posición
                      </span>
                      <span class="val font-bold text-white text-right max-w-[60%]">
                        {p.pos}
                      </span>
                    </>
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section
    id="info"
    class="info-section w-full min-h-screen flex justify-center items-center relative z-10 py-12"
  >
    <div class="info-content flex flex-col items-center text-center gap-11">
      <div class="logo-wrapper animate-up">
        <Image class="logo-large" src={logo} alt="Logo de 412" />
        <div class="logo-aura"></div>
      </div>
      <h1 class="main-title animate-up uppercase m-0">
        <span class="sr-only!">412 - </span>
        EL PROGRAMA DE FÚTBOL
      </h1>

      <a
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="kick-btn animate-up"
        id="next-stream-btn"
      >
        <svg
          class="kick-logo w-[45px] h-[45px]"
          viewBox="0 0 512 512"
          xmlns="http://www.w3.org/2000/svg"
          fill-rule="evenodd"
          clip-rule="evenodd"
          stroke-linejoin="round"
          stroke-miterlimit="2"
        >
          <path
            d="M37 .036h164.448v113.621h54.71v-56.82h54.731V.036h164.448v170.777h-54.73v56.82h-54.711v56.8h54.71v56.82h54.73V512.03H310.89v-56.82h-54.73v-56.8h-54.711v113.62H37V.036z"
            fill="currentColor"></path>
        </svg>
        <div class="btn-text flex flex-col items-start">
          <span
            class="btn-subtitle uppercase text-[0.7rem] md:text-[0.85rem] font-extrabold tracking-[1px] md:tracking-[2px] opacity-80"
            >PRÓXIMO PROGRAMA</span
          >
          <span
            class="btn-title text-[1.2rem] md:text-[1.6rem] font-black tracking-[1px]"
            id="next-stream-text">Calculando...</span
          >
        </div>
      </a>
    </div>
  </section>
</Layout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);
  ScrollTrigger.normalizeScroll(false);
  ScrollTrigger.config({ ignoreMobileResize: true });

  gsap.defaults({ overwrite: 'auto' });

  let isAnimationDone = false;

  const hitCanvas = document.createElement('canvas');
  hitCanvas.width = 1;
  hitCanvas.height = 1;
  const hitCtx = hitCanvas.getContext('2d', { willReadFrequently: true });

  function getAlphaAt(img: HTMLImageElement, clientX: number, clientY: number) {
    if (!img.naturalWidth || !hitCtx) return 0;
    const rect = img.getBoundingClientRect();
    const imgRatio = img.naturalWidth / img.naturalHeight;
    const boxRatio = rect.width / rect.height;
    let renderWidth,
      renderHeight,
      offsetX = 0,
      offsetY = 0;
    if (imgRatio > boxRatio) {
      renderWidth = rect.width;
      renderHeight = rect.width / imgRatio;
      offsetY = rect.height - renderHeight; // object-position: bottom
    } else {
      renderHeight = rect.height;
      renderWidth = rect.height * imgRatio;
      offsetX = (rect.width - renderWidth) / 2;
    }
    const x = clientX - rect.left - offsetX;
    const y = clientY - rect.top - offsetY;
    if (x < 0 || x > renderWidth || y < 0 || y > renderHeight) return 0;
    const origX = Math.floor((x / renderWidth) * img.naturalWidth);
    const origY = Math.floor((y / renderHeight) * img.naturalHeight);
    hitCtx.clearRect(0, 0, 1, 1);
    hitCtx.drawImage(img, origX, origY, 1, 1, 0, 0, 1, 1);
    return hitCtx.getImageData(0, 0, 1, 1).data[3];
  }

  const mm = gsap.matchMedia();

  mm.add('(min-width: 768px)', () => {
    gsap.set('.character', { visibility: 'visible' });

    const container = document.querySelector(
      '.characters-container',
    ) as HTMLElement | null;
    const characters = document.querySelectorAll(
      '.character',
    ) as NodeListOf<HTMLElement>;
    const desktopCards = document.querySelectorAll('.desktop-card');

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: '.hero-section',
        start: 'top top',
        end: '+=1200',
        pin: true,
        scrub: 1,
        onUpdate: (self) => {
          const wasDone = isAnimationDone;
          isAnimationDone = self.progress > 0.85;

          if (isAnimationDone) {
            characters.forEach((c) => c.classList.add('interactive'));
          } else {
            if (wasDone) {
              desktopCards.forEach((card) => card.classList.remove('visible'));

              characters.forEach((img) => {
                img.style.setProperty(
                  'filter',
                  'grayscale(0%) blur(0px) brightness(1)',
                  'important',
                );
                img.style.setProperty('transform', 'none', 'important');
                img.style.setProperty('z-index', '', 'important');
              });

              if (container) container.style.cursor = 'default';

              setTimeout(() => {
                if (!isAnimationDone) {
                  characters.forEach((img) => {
                    img.classList.remove('interactive');
                    img.style.removeProperty('filter');
                    img.style.removeProperty('transform');
                    img.style.removeProperty('z-index');
                  });
                }
              }, 400);
            } else if (self.progress < 0.85) {
              characters.forEach((c) => c.classList.remove('interactive'));
            }
          }
        },
      },
    });

    tl.to('.logo-container', {
      y: -50,
      opacity: 0,
      scale: 0.9,
      filter: 'blur(10px)',
      duration: 1,
      ease: 'power2.inOut',
    }).to('.scroll-indicator', { opacity: 0, y: 20, duration: 0.5 }, '<');

    tl.from(
      '.character',
      {
        y: 150,
        x: (index: number) => {
          const offsets = [-300, -150, 0, 150, 300];
          return offsets[index];
        },
        opacity: 0,
        scale: 1.5,
        filter: 'blur(20px)',
        duration: 2,
        stagger: { amount: 1, from: 'center' },
        ease: 'power3.out',
      },
      '-=0.5',
    );

    // === Desktop: hover pixel-perfect ===
    const images = Array.from(characters) as HTMLImageElement[];

    const sortedImages = [...images].sort((a, b) => {
      const zA = parseInt(window.getComputedStyle(a).zIndex) || 0;
      const zB = parseInt(window.getComputedStyle(b).zIndex) || 0;
      return zB - zA;
    });

    container.addEventListener('mousemove', (e: MouseEvent) => {
      if (!isAnimationDone) return;
      let hoveredImg: HTMLImageElement | null = null;
      for (const img of sortedImages) {
        if (getAlphaAt(img, e.clientX, e.clientY) > 0) {
          hoveredImg = img;
          break;
        }
      }

      if (hoveredImg) {
        const playerId = Array.from(hoveredImg.classList).find((c) =>
          c.startsWith('p'),
        );
        images.forEach((img) => {
          if (img === hoveredImg) {
            img.style.setProperty(
              'filter',
              'grayscale(0%) blur(0px) brightness(1.1)',
              'important',
            );
            img.style.setProperty(
              'transform',
              'scale(1.03) translateY(-10px)',
              'important',
            );
            img.style.setProperty('z-index', '10', 'important');
          } else {
            img.style.setProperty(
              'filter',
              'grayscale(100%) blur(0px) brightness(0.6)',
              'important',
            );
            img.style.setProperty('transform', 'none', 'important');
            img.style.setProperty('z-index', '', 'important');
          }
        });
        desktopCards.forEach((card) => {
          card.classList.toggle(
            'visible',
            card.classList.contains(`card-${playerId}`),
          );
        });
        container.style.cursor = 'pointer';
      } else {
        images.forEach((img) => {
          img.style.setProperty(
            'filter',
            'grayscale(0%) blur(0px) brightness(1)',
            'important',
          );
          img.style.setProperty('transform', 'none', 'important');
          img.style.setProperty('z-index', '', 'important');
        });
        desktopCards.forEach((card) => card.classList.remove('visible'));
        container.style.cursor = 'default';
      }
    });

    container.addEventListener('mouseleave', () => {
      if (!isAnimationDone) return;
      images.forEach((img) => {
        img.style.setProperty(
          'filter',
          'grayscale(0%) blur(0px) brightness(1)',
          'important',
        );
        img.style.setProperty('transform', 'none', 'important');
        img.style.setProperty('z-index', '', 'important');
      });
      desktopCards.forEach((card) => card.classList.remove('visible'));
      container.style.cursor = 'default';
    });
  });

  mm.add('(max-width: 767px)', () => {
    gsap.set('.character', { visibility: 'visible' });

    gsap.fromTo(
      '.logo-container',
      { opacity: 1, y: 0, scale: 1 },
      {
        scrollTrigger: {
          trigger: '.hero-section',
          start: 'top top',
          end: '200px top',
          scrub: 0.5,
        },
        opacity: 0,
        y: -40,
        scale: 0.9,
      },
    );

    gsap.fromTo(
      '.scroll-indicator',
      { opacity: 1 },
      {
        scrollTrigger: {
          trigger: '.hero-section',
          start: 'top top',
          end: '100px top',
          scrub: 0.5,
        },
        opacity: 0,
      },
    );

    gsap.fromTo(
      '.character',
      { opacity: 0, y: 400, scale: 0.4, filter: 'blur(30px)' },
      {
        scrollTrigger: {
          trigger: '.hero-section',
          start: 'top top',
          end: '+=70svh',
          scrub: 0.5,
          onLeave: () => {
            isAnimationDone = true;
          },
          onEnterBack: () => {
            isAnimationDone = true;
          },
          onLeaveBack: () => {
            isAnimationDone = false;
            clearCards();
          },
        },
        opacity: 1,
        y: 0,
        scale: 1,
        filter: 'blur(0px)',
        stagger: { amount: 0.4, from: 'center' },
      },
    );

    const images = Array.from(
      document.querySelectorAll('.character'),
    ) as HTMLImageElement[];
    const mobileCards = Array.from(
      document.querySelectorAll('.player-card-mobile'),
    );
    const cardZone = document.getElementById('mobile-card-zone');
    let activeTap: string | null = null;

    function showCard(playerId: string) {
      activeTap = playerId;
      images.forEach((i) => {
        if (i.dataset.player === playerId) {
          i.style.setProperty(
            'filter',
            'grayscale(0%) brightness(1.1)',
            'important',
          );
          i.style.setProperty('transform', 'scale(1.05)', 'important');
        } else {
          i.style.setProperty(
            'filter',
            'grayscale(100%) brightness(0.5)',
            'important',
          );
          i.style.setProperty('transform', 'none', 'important');
        }
      });
      mobileCards.forEach((card) => {
        card.classList.toggle(
          'visible',
          card.classList.contains(`card-mobile-${playerId}`),
        );
      });
      const clickIndicator = document.getElementById('mobile-click-indicator');
      if (clickIndicator) clickIndicator.style.opacity = '0';
      if (cardZone) cardZone.classList.add('active');
    }

    function clearCards() {
      activeTap = null;
      images.forEach((i) => {
        i.style.setProperty(
          'filter',
          'grayscale(0%) brightness(1)',
          'important',
        );
        i.style.setProperty('transform', 'none', 'important');
      });
      mobileCards.forEach((c) => c.classList.remove('visible'));
      const clickIndicator = document.getElementById('mobile-click-indicator');
      if (clickIndicator) clickIndicator.style.opacity = '1';
      if (cardZone) cardZone.classList.remove('active');
    }

    const sortedMobileImages = [...images].sort((a, b) => {
      const zA = parseInt(window.getComputedStyle(a).zIndex) || 0;
      const zB = parseInt(window.getComputedStyle(b).zIndex) || 0;
      return zB - zA;
    });

    document.addEventListener('click', (e) => {
      if (!isAnimationDone) return;
      const target = e.target as HTMLElement;

      let clickedImg: HTMLImageElement | null = null;
      // Pixel perfect collision detection
      for (const img of sortedMobileImages) {
        if (getAlphaAt(img, e.clientX, e.clientY) > 0) {
          clickedImg = img;
          break;
        }
      }

      if (clickedImg) {
        const playerId = clickedImg.dataset.player;
        if (!playerId) return;
        if (activeTap === playerId) {
          clearCards();
        } else {
          showCard(playerId);
        }
      } else if (!target.closest('.player-card-mobile')) {
        clearCards();
      }
    });
  });

  // Próximo programa: calcula Lunes (Davo) o Viernes (Cobra) client-side
  const updateNextStream = () => {
    const now = new Date();
    const dayOfWeek = now.getDay();
    const hour = now.getHours();

    let nextStreamDay = 'LUNES';
    let nextStreamLink = 'https://kick.com/davoxeneize';

    if (
      (dayOfWeek === 1 && hour >= 22) ||
      dayOfWeek === 2 ||
      dayOfWeek === 3 ||
      dayOfWeek === 4 ||
      (dayOfWeek === 5 && hour < 22)
    ) {
      nextStreamDay = 'VIERNES';
      nextStreamLink = 'https://kick.com/lacobraaa';
    }

    const btn = document.getElementById('next-stream-btn');
    const text = document.getElementById('next-stream-text');
    if (btn && text) {
      btn.setAttribute('href', nextStreamLink);
      text.textContent = `${nextStreamDay} 22HS`;
    }
  };

  updateNextStream();

  gsap.to('.animate-up', {
    scrollTrigger: {
      trigger: '.info-section',
      start: 'top 75%',
    },
    y: 0,
    opacity: 1,
    duration: 1,
    stagger: 0.2,
    ease: 'power3.out',
  });
</script>

<style>
  body {
    background-color: #000;
  }

  .logo-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 0;
  }

  .logo {
    width: 300px;
    filter: drop-shadow(0 0 5px rgba(0, 231, 1, 0.2));
  }

  .scroll-indicator {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    color: rgba(255, 255, 255, 0.6);
    font-family: sans-serif;
    letter-spacing: 3px;
    font-size: 10px;
    z-index: 20;
    pointer-events: none;
  }

  .scroll-indicator .arrow {
    width: 2px;
    height: 40px;
    background-color: rgba(255, 255, 255, 0.1);
    margin-top: 10px;
    position: relative;
    overflow: hidden;
  }

  .scroll-indicator .arrow::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(transparent, #00e701, transparent);
    animation: scroll-down 1.5s infinite ease-in-out;
  }

  @keyframes scroll-down {
    0% {
      transform: translateY(-100%);
    }
    100% {
      transform: translateY(100%);
    }
  }

  .characters-container {
    position: relative;
    width: 100%;
    height: 80vh;
    display: flex;
    justify-content: center;
    align-items: flex-end;
    -webkit-mask-image: linear-gradient(to top, transparent 0%, black 40%);
    mask-image: linear-gradient(to top, transparent 0%, black 40%);
  }

  .character {
    position: relative;
    height: 100%;
    object-fit: contain;
    object-position: bottom center;
    margin: -5% -8%;
    -webkit-user-drag: none;
    user-select: none;
    visibility: hidden;
  }

  .interactive {
    transition:
      filter 0.4s ease,
      transform 0.4s ease !important;
  }

  /* Desktop player cards (glassmorphism) */
  .player-card {
    position: absolute;
    width: 260px;
    background: rgba(15, 20, 15, 0.65);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(74, 222, 128, 0.2);
    border-radius: 16px;
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.5),
