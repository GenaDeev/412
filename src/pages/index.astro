---
import Layout from '../layouts/Layout.astro';
import Image from 'astro/components/Image.astro';

import agus from '../assets/images/agus0.webp';
import teo from '../assets/images/teo0.webp';
import davo from '../assets/images/davo0.webp';
import nine from '../assets/images/nine0.webp';
import beno from '../assets/images/beno0.webp';
import logo from '../assets/images/logo.webp';

const players = [
  {
    id: 'p1',
    yt: 'AGUSNETA',
    realName: 'Agustín',
    age: '24',
    weight: '75kg',
    nicknames: 'Gordo, Agus',
    pos: 'DFC',
  },
  {
    id: 'p2',
    yt: "TEO D'ELIA",
    realName: 'Teo',
    age: '22',
    weight: '70kg',
    nicknames: 'Teito, Figo',
    pos: 'MCO',
  },
  {
    id: 'p3',
    yt: 'DAVO XENEIZE',
    realName: 'David',
    age: '21',
    weight: '65kg',
    nicknames: 'Puerro, Davito',
    pos: 'EI',
  },
  {
    id: 'p4',
    yt: 'LA COBRA',
    realName: 'Lautaro',
    age: '26',
    weight: '110kg',
    nicknames: 'Nine, Big Nine, Enormous Nine',
    pos: 'DC',
  },
  {
    id: 'p5',
    yt: 'BENITO SDR',
    realName: 'Benito',
    age: '23',
    weight: '70kg',
    nicknames: 'Beno',
    pos: 'DT',
  },
];
---

<Layout>
  <section
    class="hero-section w-full h-screen flex justify-center items-center relative"
  >
    <div class="logo-container">
      <div class="logo-wrapper">
        <Image class="logo" src={logo} alt="Logo de 412" />
        <div class="logo-aura"></div>
      </div>
    </div>
    <div class="scroll-indicator">
      <span>SCROLLEA</span>
      <div class="arrow"></div>
    </div>
    <div class="characters-container">
      <!--  Agusneta | Teo | Davo (centro) | La Cobra | Benito — formación en V -->
      <Image
        src={agus}
        class="character p1"
        alt="Agusneta"
        width="400"
        height="600"
      />
      <Image
        src={teo}
        class="character p2"
        alt="Teo"
        width="400"
        height="600"
      />
      <Image
        src={davo}
        class="character p3"
        alt="Davo"
        width="400"
        height="600"
      />
      <Image
        src={nine}
        class="character p4"
        alt="La Cobra"
        width="400"
        height="600"
      />
      <Image
        src={beno}
        class="character p5"
        alt="Benito"
        width="400"
        height="600"
      />

      {
        players.map((p) => (
          <div class={`player-card card-${p.id}`}>
            <div class="card-inner flex flex-col h-full">
              <h3 class="name">{p.yt}</h3>
              <div class="card-divider" />
              <div class="info-list flex flex-col gap-3">
                <div class="info-row flex justify-between items-center">
                  <>
                    <span class="label">Nombre</span>
                    <span class="val">{p.realName}</span>
                  </>
                </div>
                <div class="info-row flex justify-between items-center">
                  <>
                    <span class="label">Edad</span>
                    <span class="val">{p.age}</span>
                  </>
                </div>
                <div class="info-row flex justify-between items-center">
                  <>
                    <span class="label">Peso</span>
                    <span class="val">{p.weight}</span>
                  </>
                </div>
                <div class="info-row flex justify-between items-center">
                  <>
                    <span class="label">Apodos</span>
                    <span class="val">{p.nicknames}</span>
                  </>
                </div>
                <div class="info-row flex justify-between items-center">
                  <>
                    <span class="label">Posición</span>
                    <span class="val">{p.pos}</span>
                  </>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section
    class="info-section w-full min-h-screen flex justify-center items-center relative z-10"
  >
    <div class="info-content flex flex-col items-center text-center gap-11">
      <div class="logo-wrapper animate-up">
        <Image class="logo-large" src={logo} alt="Logo de 412" />
        <div class="logo-aura"></div>
      </div>
      <h1 class="main-title animate-up uppercase m-0">
        <span class="sr-only!">412 - </span>
        EL PROGRAMA DE FÚTBOL
      </h1>

      <a
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="kick-btn animate-up"
        id="next-stream-btn"
      >
        <svg
          class="kick-logo w-[45px] h-[45px]"
          viewBox="0 0 512 512"
          xmlns="http://www.w3.org/2000/svg"
          fill-rule="evenodd"
          clip-rule="evenodd"
          stroke-linejoin="round"
          stroke-miterlimit="2"
        >
          <path
            d="M37 .036h164.448v113.621h54.71v-56.82h54.731V.036h164.448v170.777h-54.73v56.82h-54.711v56.8h54.71v56.82h54.73V512.03H310.89v-56.82h-54.73v-56.8h-54.711v113.62H37V.036z"
            fill="currentColor"></path>
        </svg>
        <div class="btn-text flex flex-col items-start">
          <span class="btn-subtitle uppercase">PRÓXIMO PROGRAMA</span>
          <span class="btn-title" id="next-stream-text">Calculando...</span>
        </div>
      </a>
    </div>
  </section>
</Layout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Previene FOUC: las imágenes arrancan con visibility:hidden en CSS
  gsap.set('.character', { visibility: 'visible' });

  let isAnimationDone = false;

  const tl = gsap.timeline({
    scrollTrigger: {
      trigger: '.hero-section',
      start: 'top top',
      end: '+=1200',
      pin: true,
      scrub: 1,
      onUpdate: (self) => {
        const wasDone = isAnimationDone;
        isAnimationDone = self.progress === 1;

        const container: HTMLElement | null = document.querySelector(
          '.characters-container',
        );
        const characters = document.querySelectorAll(
          '.character',
        ) as NodeListOf<HTMLElement>;

        if (isAnimationDone) {
          characters.forEach((c) => c.classList.add('interactive'));
        } else {
          // Salida suave: esperamos la CSS transition antes de devolver control a GSAP
          if (wasDone) {
            document
              .querySelectorAll('.player-card')
              .forEach((card) => card.classList.remove('visible'));

            characters.forEach((img) => {
              img.style.setProperty(
                'filter',
                'grayscale(0%) blur(0px) brightness(1)',
                'important',
              );
              img.style.setProperty('transform', 'none', 'important');
              img.style.setProperty('z-index', '', 'important');
            });

            if (container) {
              container.style.cursor = 'default';
            }

            // Esperar la CSS transition (400ms) antes de limpiar inline styles
            setTimeout(() => {
              if (!isAnimationDone) {
                characters.forEach((img) => {
                  img.classList.remove('interactive');
                  img.style.removeProperty('filter');
                  img.style.removeProperty('transform');
                  img.style.removeProperty('z-index');
                });
              }
            }, 400);
          } else if (self.progress < 0.95) {
            characters.forEach((c) => c.classList.remove('interactive'));
          }
        }
      },
    },
  });

  // Timeline: Logo sale → Personajes entran
  tl.to('.logo-container', {
    y: -50,
    opacity: 0,
    scale: 0.9,
    filter: 'blur(10px)',
    duration: 1,
    ease: 'power2.inOut',
  }).to(
    '.scroll-indicator',
    {
      opacity: 0,
      y: 20,
      duration: 0.5,
    },
    '<',
  );

  tl.from(
    '.character',
    {
      y: 150,
      x: (index) => {
        const offsets = [-300, -150, 0, 150, 300];
        return offsets[index];
      },
      opacity: 0,
      scale: 1.5,
      filter: 'blur(20px)',
      duration: 2,
      stagger: {
        amount: 1,
        from: 'center',
      },
      ease: 'power3.out',
    },
    '-=0.5',
  );

  // Hover pixel-perfect: ignora áreas transparentes de los PNG
  const $ = (selector: string) => document.querySelector(selector);
  const $$ = (selector: string) => document.querySelectorAll(selector);

  const container = $('.characters-container') as HTMLElement;
  const images = Array.from($$('.character')) as HTMLImageElement[];

  const sortedImages = [...images].sort((a, b) => {
    const zA = parseInt(window.getComputedStyle(a).zIndex) || 0;
    const zB = parseInt(window.getComputedStyle(b).zIndex) || 0;
    return zB - zA;
  });

  const hitCanvas = document.createElement('canvas');
  hitCanvas.width = 1;
  hitCanvas.height = 1;
  const hitCtx = hitCanvas.getContext('2d', { willReadFrequently: true });

  function getAlphaAt(img: HTMLImageElement, clientX: number, clientY: number) {
    if (!img.naturalWidth || !hitCtx) return 0;

    const rect = img.getBoundingClientRect();
    const imgRatio = img.naturalWidth / img.naturalHeight;
    const boxRatio = rect.width / rect.height;

    let renderWidth,
      renderHeight,
      offsetX = 0,
      offsetY = 0;
    if (imgRatio > boxRatio) {
      renderWidth = rect.width;
      renderHeight = rect.width / imgRatio;
      offsetY = (rect.height - renderHeight) / 2;
    } else {
      renderHeight = rect.height;
      renderWidth = rect.height * imgRatio;
      offsetX = (rect.width - renderWidth) / 2;
    }

    const x = clientX - rect.left - offsetX;
    const y = clientY - rect.top - offsetY;

    if (x < 0 || x > renderWidth || y < 0 || y > renderHeight) return 0;

    const origX = Math.floor((x / renderWidth) * img.naturalWidth);
    const origY = Math.floor((y / renderHeight) * img.naturalHeight);

    hitCtx.clearRect(0, 0, 1, 1);
    hitCtx.drawImage(img, origX, origY, 1, 1, 0, 0, 1, 1);
    return hitCtx.getImageData(0, 0, 1, 1).data[3];
  }

  const cards = Array.from($$('.player-card'));

  container.addEventListener('mousemove', (e: MouseEvent) => {
    if (!isAnimationDone) return;

    let hoveredImg = null;

    for (const img of sortedImages) {
      if (getAlphaAt(img, e.clientX, e.clientY) > 0) {
        hoveredImg = img;
        break;
      }
    }

    if (hoveredImg) {
      const playerId = Array.from(hoveredImg.classList).find((c) =>
        c.startsWith('p'),
      );

      images.forEach((img) => {
        if (img === hoveredImg) {
          img.style.setProperty(
            'filter',
            'grayscale(0%) blur(0px) brightness(1.1)',
            'important',
          );
          img.style.setProperty(
            'transform',
            'scale(1.03) translateY(-10px)',
            'important',
          );
          img.style.setProperty('z-index', '10', 'important');
        } else {
          img.style.setProperty(
            'filter',
            'grayscale(100%) blur(0px) brightness(0.6)',
            'important',
          );
          img.style.setProperty('transform', 'none', 'important');
          img.style.setProperty('z-index', '', 'important');
        }
      });

      cards.forEach((card) => {
        if (card.classList.contains(`card-${playerId}`)) {
          card.classList.add('visible');
        } else {
          card.classList.remove('visible');
        }
      });

      container.style.cursor = 'pointer';
    } else {
      images.forEach((img) => {
        img.style.setProperty(
          'filter',
          'grayscale(0%) blur(0px) brightness(1)',
          'important',
        );
        img.style.setProperty('transform', 'none', 'important');
        img.style.setProperty('z-index', '', 'important');
      });
      cards.forEach((card) => card.classList.remove('visible'));
      container.style.cursor = 'default';
    }
  });

  container.addEventListener('mouseleave', () => {
    if (!isAnimationDone) return;
    images.forEach((img) => {
      img.style.setProperty(
        'filter',
        'grayscale(0%) blur(0px) brightness(1)',
        'important',
      );
      img.style.setProperty('transform', 'none', 'important');
      img.style.setProperty('z-index', '', 'important');
    });
    cards.forEach((card) => card.classList.remove('visible'));
    container.style.cursor = 'default';
  });

  // Próximo programa: calcula Lunes (Davo) o Viernes (Cobra) client-side
  const updateNextStream = () => {
    const now = new Date();
    const dayOfWeek = now.getDay();
    const hour = now.getHours();

    let nextStreamDay = 'LUNES';
    let nextStreamLink = 'https://kick.com/davoxeneize';

    if (
      (dayOfWeek === 1 && hour >= 22) ||
      dayOfWeek === 2 ||
      dayOfWeek === 3 ||
      dayOfWeek === 4 ||
      (dayOfWeek === 5 && hour < 22)
    ) {
      nextStreamDay = 'VIERNES';
      nextStreamLink = 'https://kick.com/lacobraaa';
    }

    const btn = document.getElementById('next-stream-btn');
    const text = document.getElementById('next-stream-text');

    if (btn && text) {
      btn.setAttribute('href', nextStreamLink);
      text.textContent = `${nextStreamDay} 22HS`;
    }
  };

  updateNextStream();

  gsap.to('.animate-up', {
    scrollTrigger: {
      trigger: '.info-section',
      start: 'top 75%',
    },
    y: 0,
    opacity: 1,
    duration: 1,
    stagger: 0.2,
    ease: 'power3.out',
  });
</script>

<style>
  body {
    background-color: #000;
    overflow-x: hidden;
  }

  .logo-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 0;
  }

  .logo {
    width: 300px;
    filter: drop-shadow(0 0 5px rgba(0, 231, 1, 0.2));
  }

  .scroll-indicator {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    color: rgba(255, 255, 255, 0.6);
    font-family: sans-serif;
    letter-spacing: 3px;
    font-size: 10px;
    z-index: 20;
    pointer-events: none;
  }

  .scroll-indicator .arrow {
    width: 2px;
    height: 40px;
    background-color: rgba(255, 255, 255, 0.1);
    margin-top: 10px;
    position: relative;
    overflow: hidden;
  }

  .scroll-indicator .arrow::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(transparent, #00e701, transparent);
    animation: scroll-down 1.5s infinite ease-in-out;
  }

  @keyframes scroll-down {
    0% {
      transform: translateY(-100%);
    }
    100% {
      transform: translateY(100%);
    }
  }

  .characters-container {
    position: relative;
    width: 100%;
    height: 80vh;
    display: flex;
    justify-content: center;
    align-items: flex-end;
    -webkit-mask-image: linear-gradient(to top, transparent 0%, black 40%);
    mask-image: linear-gradient(to top, transparent 0%, black 40%);
  }

  .character {
    position: relative;
    height: 100%;
    object-fit: contain;
    margin: 0 -8%;
    -webkit-user-drag: none;
    user-select: none;
    visibility: hidden; /* FOUC prevention — GSAP reveals on init */
  }

  /* Transición solo post-animación para no interferir con GSAP scrub */
  .interactive {
    transition:
      filter 0.4s ease,
      transform 0.4s ease !important;
  }

  /* Player cards (glassmorphism) */
  .player-card {
    position: absolute;
    width: 260px;
    background: rgba(15, 20, 15, 0.65);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(74, 222, 128, 0.2);
    border-radius: 16px;
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.5),
      inset 0 0 0 1px rgba(255, 255, 255, 0.05);
    color: white;
    font-family: 'Inter', sans-serif;
    padding: 25px 20px;
    opacity: 0;
    pointer-events: none;
    transform: translateY(20px) scale(0.95);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    z-index: 20;
    display: flex;
    flex-direction: column;
  }

  .player-card.visible {
    opacity: 1;
    transform: translateY(0) scale(1);
    border-color: #00e701;
    box-shadow:
      0 10px 40px rgba(0, 231, 1, 0.2),
      inset 0 0 20px rgba(0, 231, 1, 0.2);
  }

  .card-p1 {
    left: 5%;
    top: 30%;
  }
  .card-p2 {
    left: 18%;
    top: 20%;
  }
  .card-p3 {
    left: 50%;
    top: 45%;
    transform: translateX(-50%) translateY(20px) scale(0.95);
  }
  .card-p3.visible {
    transform: translateX(-50%) translateY(0) scale(1);
  }
  .card-p4 {
    right: 18%;
    top: 20%;
  }
  .card-p5 {
    right: 5%;
    top: 30%;
  }

  .card-inner h3.name {
    font-size: 1.6rem;
    font-weight: 900;
    text-align: center;
    margin: 0 0 15px 0;
    letter-spacing: 1px;
    color: #00e701;
    text-transform: uppercase;
    text-shadow: 0 0 10px rgba(0, 231, 1, 0.6);
  }

  .card-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(74, 222, 128, 0.5),
      transparent
    );
    margin: 0 0 15px 0;
  }

  .info-row {
    font-size: 0.95rem;
  }

  .info-row .label {
    color: rgba(255, 255, 255, 0.5);
    font-weight: 500;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .info-row .val {
    font-weight: 700;
    color: #fff;
    text-align: right;
    max-width: 60%;
  }

  .info-section {
    background: radial-gradient(circle at center, #0a120a 0%, #000 100%);
  }

  .animate-up {
    opacity: 0;
    transform: translateY(50px);
  }

  .logo-large {
    width: 350px;
    filter: drop-shadow(0 0 5px rgba(0, 231, 1, 0.2));
  }

  /* Rotating neon aura — mask-image + conic-gradient + drop-shadow */
  .logo-wrapper {
    position: relative;
    display: inline-flex;
    justify-content: center;
    align-items: center;
  }

  .logo-aura {
    position: absolute;
    top: -1%;
    left: -1%;
    width: 102%;
    height: 102%;
    z-index: 1;
    overflow: hidden;

    -webkit-mask-image: url('../assets/images/logo.webp');
    -webkit-mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-image: url('../assets/images/logo.webp');
    mask-size: contain;
    mask-repeat: no-repeat;
    mask-position: center;

    filter: drop-shadow(0 0 4px #00e701) drop-shadow(0 0 12px #00e701)
      drop-shadow(0 0 25px rgba(0, 231, 1, 0.6));
    pointer-events: none;
  }

  .logo-aura::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: conic-gradient(
      from 0deg,
      transparent 0%,
      transparent 60%,
      #00e701 90%,
      transparent 100%
    );
    animation: spin 2.5s linear infinite;
  }

  .logo,
  .logo-large {
    position: relative;
    filter: drop-shadow(0 0 2px #00e701)
      drop-shadow(0 0 4px rgba(0, 231, 1, 0.2))
      drop-shadow(0 0 24px rgba(0, 231, 1, 0.4));
    z-index: 2;
  }

  @keyframes spin {
    100% {
      transform: rotate(360deg);
    }
  }

  .main-title {
    color: white;
    font-size: 4.5rem;
    font-weight: 900;
    letter-spacing: 2px;
    text-shadow: 0 4px 20px rgba(0, 0, 0, 0.8);
    font-family: 'Impact', 'Arial Black', sans-serif;
    font-style: italic;
  }

  .kick-btn {
    display: flex;
    align-items: center;
    gap: 15px;
    background: #00e701;
    color: #000;
    padding: 15px 35px;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 0 25px rgba(0, 231, 1, 0.4);
    font-family: 'Inter', sans-serif;
  }

  .kick-btn:hover {
    transform: translateY(-5px) scale(1.05);
    box-shadow: 0 10px 40px rgba(0, 231, 1, 0.6);
  }

  .btn-subtitle {
    font-size: 0.85rem;
    font-weight: 800;
    letter-spacing: 2px;
    opacity: 0.8;
  }

  .btn-title {
    font-size: 1.6rem;
    font-weight: 900;
    letter-spacing: 1px;
  }

  .p1 {
    z-index: 1;
    height: 85%;
  }
  .p2 {
    z-index: 2;
    height: 92%;
  }
  .p3 {
    z-index: 3;
    height: 100%;
  }
  .p4 {
    z-index: 2;
    height: 92%;
  }
  .p5 {
    z-index: 1;
    height: 85%;
  }
</style>
